{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "behavior": {
      "type": "string",
      "enum": [
        "unverified",
        "at-risk",
        "supported",
        "refuted"
      ]
    },
    "advisories": {
      "default": [],
      "type": "array",
      "items": {
        "$ref": "#/$defs/Advisory"
      }
    },
    "notes": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "behavior",
    "advisories",
    "notes"
  ],
  "additionalProperties": false,
  "$defs": {
    "Advisory": {
      "type": "object",
      "properties": {
        "resolver": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "confidence": {
          "type": "number"
        }
      },
      "required": [
        "resolver",
        "message"
      ],
      "additionalProperties": false
    }
  }
}
