{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "verdict": {
      "type": "object",
      "properties": {
        "assertionId": {
          "type": "string"
        },
        "propositionId": {
          "type": "string"
        },
        "documentId": {
          "type": "string"
        },
        "doc": {
          "$ref": "#/$defs/__schema0"
        },
        "code": {
          "$ref": "#/$defs/__schema0"
        },
        "behavior": {
          "type": "string",
          "enum": [
            "unverified",
            "at-risk",
            "supported",
            "refuted"
          ]
        },
        "expired": {
          "type": "boolean"
        },
        "gates": {
          "type": "boolean"
        },
        "evidence": {
          "type": "object",
          "properties": {
            "docRegion": {
              "$ref": "#/$defs/__schema1"
            },
            "codeRegions": {
              "default": [],
              "type": "array",
              "items": {
                "$ref": "#/$defs/__schema1"
              }
            },
            "confidence": {
              "type": "number"
            },
            "selectorScores": {
              "default": [],
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string"
                  },
                  "found": {
                    "type": "boolean"
                  },
                  "score": {
                    "type": "number"
                  },
                  "weight": {
                    "type": "number"
                  }
                },
                "required": [
                  "kind",
                  "found",
                  "score",
                  "weight"
                ],
                "additionalProperties": false
              }
            },
            "changedEvidence": {
              "default": [],
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "path": {
                    "type": "string"
                  },
                  "kind": {
                    "type": "string"
                  },
                  "detail": {
                    "type": "string"
                  }
                },
                "required": [
                  "path",
                  "kind"
                ],
                "additionalProperties": false
              }
            },
            "ref": {
              "type": "string"
            }
          },
          "required": [
            "codeRegions",
            "confidence",
            "selectorScores",
            "changedEvidence"
          ],
          "additionalProperties": false
        },
        "notes": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "advisories": {
          "default": [],
          "type": "array",
          "items": {
            "$ref": "#/$defs/__schema2"
          }
        }
      },
      "required": [
        "assertionId",
        "propositionId",
        "documentId",
        "doc",
        "code",
        "expired",
        "gates",
        "evidence",
        "notes",
        "advisories"
      ],
      "additionalProperties": false
    },
    "advisories": {
      "default": [],
      "type": "array",
      "items": {
        "$ref": "#/$defs/__schema2"
      }
    }
  },
  "required": [
    "advisories"
  ],
  "additionalProperties": false,
  "$defs": {
    "__schema0": {
      "type": "string",
      "enum": [
        "unchanged",
        "moved",
        "changed",
        "ambiguous",
        "orphaned"
      ]
    },
    "__schema1": {
      "type": "object",
      "properties": {
        "start": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "end": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        }
      },
      "required": [
        "start",
        "end"
      ],
      "additionalProperties": false
    },
    "__schema2": {
      "type": "object",
      "properties": {
        "resolver": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "confidence": {
          "type": "number"
        }
      },
      "required": [
        "resolver",
        "message"
      ],
      "additionalProperties": false
    }
  }
}
