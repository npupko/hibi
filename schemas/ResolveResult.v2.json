{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "verdict": {
      "type": "object",
      "properties": {
        "assertionId": {
          "type": "string"
        },
        "propositionId": {
          "type": "string"
        },
        "documentId": {
          "type": "string"
        },
        "doc": {
          "$ref": "#/$defs/AnchorState"
        },
        "code": {
          "$ref": "#/$defs/AnchorState"
        },
        "behavior": {
          "type": "string",
          "enum": [
            "unverified",
            "at-risk",
            "supported",
            "refuted"
          ]
        },
        "expired": {
          "type": "boolean"
        },
        "gates": {
          "type": "boolean"
        },
        "remediation": {
          "default": null,
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "recommended": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "actions": {
                  "default": [],
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string"
                      },
                      "title": {
                        "type": "string"
                      },
                      "applicability": {
                        "type": "string",
                        "enum": [
                          "auto",
                          "needs-review",
                          "manual"
                        ]
                      },
                      "effect": {
                        "type": "string",
                        "enum": [
                          "deterministic",
                          "prose"
                        ]
                      },
                      "rationale": {
                        "type": "string"
                      },
                      "command": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "id",
                      "title",
                      "applicability",
                      "effect",
                      "rationale"
                    ],
                    "additionalProperties": false
                  }
                }
              },
              "required": [
                "recommended",
                "actions"
              ],
              "additionalProperties": false
            },
            {
              "type": "null"
            }
          ]
        },
        "suppressed": {
          "default": false,
          "type": "boolean"
        },
        "evidence": {
          "type": "object",
          "properties": {
            "docRegion": {
              "$ref": "#/$defs/Region"
            },
            "codeRegions": {
              "default": [],
              "type": "array",
              "items": {
                "$ref": "#/$defs/Region"
              }
            },
            "confidence": {
              "type": "number"
            },
            "selectorScores": {
              "default": [],
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string"
                  },
                  "found": {
                    "type": "boolean"
                  },
                  "score": {
                    "type": "number"
                  },
                  "weight": {
                    "type": "number"
                  }
                },
                "required": [
                  "kind",
                  "found",
                  "score",
                  "weight"
                ],
                "additionalProperties": false
              }
            },
            "changedEvidence": {
              "default": [],
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "path": {
                    "type": "string"
                  },
                  "kind": {
                    "type": "string"
                  },
                  "detail": {
                    "type": "string"
                  }
                },
                "required": [
                  "path",
                  "kind"
                ],
                "additionalProperties": false
              }
            },
            "ref": {
              "type": "string"
            }
          },
          "required": [
            "codeRegions",
            "confidence",
            "selectorScores",
            "changedEvidence"
          ],
          "additionalProperties": false
        },
        "notes": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "advisories": {
          "default": [],
          "type": "array",
          "items": {
            "$ref": "#/$defs/Advisory"
          }
        }
      },
      "required": [
        "assertionId",
        "propositionId",
        "documentId",
        "doc",
        "code",
        "expired",
        "gates",
        "remediation",
        "suppressed",
        "evidence",
        "notes",
        "advisories"
      ],
      "additionalProperties": false
    },
    "advisories": {
      "default": [],
      "type": "array",
      "items": {
        "$ref": "#/$defs/Advisory"
      }
    }
  },
  "required": [
    "advisories"
  ],
  "additionalProperties": false,
  "$defs": {
    "AnchorState": {
      "type": "string",
      "enum": [
        "unchanged",
        "moved",
        "changed",
        "ambiguous",
        "orphaned"
      ]
    },
    "Region": {
      "type": "object",
      "properties": {
        "start": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "end": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        }
      },
      "required": [
        "start",
        "end"
      ],
      "additionalProperties": false
    },
    "Advisory": {
      "type": "object",
      "properties": {
        "resolver": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "confidence": {
          "type": "number"
        },
        "provenance": {
          "type": "object",
          "properties": {
            "model": {
              "type": "string"
            },
            "promptHash": {
              "type": "string"
            },
            "contextHash": {
              "type": "string"
            },
            "params": {
              "type": "object",
              "propertyNames": {
                "type": "string"
              },
              "additionalProperties": {}
            }
          },
          "required": [
            "model",
            "promptHash",
            "contextHash"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "resolver",
        "message"
      ],
      "additionalProperties": false
    }
  }
}
