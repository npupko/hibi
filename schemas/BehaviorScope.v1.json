{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "rootSymbols": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reachableDepth": {
      "default": 2,
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "include": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "exclude": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "rootSymbols",
    "reachableDepth",
    "include",
    "exclude"
  ],
  "additionalProperties": false
}
