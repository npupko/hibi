{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "include": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "exclude": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "depth": {
      "default": 1,
      "anyOf": [
        {
          "type": "number",
          "const": 0
        },
        {
          "type": "number",
          "const": 1
        },
        {
          "type": "number",
          "const": 2
        }
      ]
    }
  },
  "required": [
    "include",
    "exclude",
    "depth"
  ],
  "additionalProperties": false
}
